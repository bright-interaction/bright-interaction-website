---
import { t } from '../i18n';
interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

// JS strings passed to client via data attribute
const i18nData = JSON.stringify({
  steps: [1,2,3,4,5,6,7].map(n => t(lang, `borderTracer.step${n}`)),
  scanComplete: t(lang, 'borderTracer.scanComplete'),
  scanFailedAlert: t(lang, 'borderTracer.scanFailedAlert'),
  scanning: t(lang, 'borderTracer.scanning'),
  ctaUS: t(lang, 'borderTracer.ctaUS'),
  ctaEU: t(lang, 'borderTracer.ctaEU'),
  headlineStrongUS: t(lang, 'borderTracer.headlineStrongUS'),
  headlineModerateUS: t(lang, 'borderTracer.headlineModerateUS'),
  headlineSignificantUS: t(lang, 'borderTracer.headlineSignificantUS'),
  headlineWeakUS: t(lang, 'borderTracer.headlineWeakUS'),
});
---

<section id="border-tracer" class="py-20 md:py-28 bg-white overflow-hidden" data-i18n={i18nData}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Globe + right panel layout -->
    <div class="flex flex-col lg:flex-row items-center gap-6 lg:gap-8">

      <!-- Globe column (left) -->
      <div class="w-full lg:flex-[3] order-2 lg:order-1 relative">
        <div id="bt-globe-container" class="relative mx-auto max-w-[320px] sm:max-w-[440px] lg:max-w-[520px]">
          <svg id="bt-globe-svg" class="w-full" viewBox="0 0 500 500"></svg>

          <!-- Status overlay (visible during scan) -->
          <div id="bt-status-overlay" class="hidden absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
            <div class="px-5 py-2.5 bg-white/90 backdrop-blur-sm border border-border rounded-xl">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 bg-gold rounded-full animate-pulse"></div>
                <p id="bt-status-text" class="text-sm text-text-secondary font-mono"></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right panel: cycles between Entry → Scanning → Results -->
      <div class="w-full lg:flex-[2] order-1 lg:order-2">

        <!-- STATE 1: Entry form -->
        <div id="bt-panel-entry" class="transition-all duration-500 ease-out">
          <div class="max-w-lg mx-auto lg:mx-0">
            <p class="text-xs font-mono font-bold text-gold-dark mb-4 tracking-widest uppercase">
              {t(lang, 'borderTracer.badge')}
            </p>
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-heading font-bold text-text-primary mb-3 leading-tight tracking-tight">
              {t(lang, 'borderTracer.title1')}<br class="hidden lg:block" />
              <span class="text-gold">{t(lang, 'borderTracer.title2')}</span>
            </h2>
            <p class="text-base text-text-secondary mb-6 leading-relaxed">
              {t(lang, 'borderTracer.description')}
            </p>

            <div class="space-y-3">
              <!-- Jurisdiction toggle -->
              <div class="flex rounded-xl bg-surface border-2 border-border p-1 gap-1">
                <button
                  id="bt-jurisdiction-eu"
                  type="button"
                  class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all bg-gold/15 text-gold border border-gold/30"
                >
                  <span class="text-base">🇪🇺</span> {t(lang, 'borderTracer.jurisdictionEU')}
                </button>
                <button
                  id="bt-jurisdiction-us"
                  type="button"
                  class="flex-1 flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg text-sm font-semibold transition-all text-text-secondary hover:text-text-secondary"
                >
                  <span class="text-base">🇺🇸</span> {t(lang, 'borderTracer.jurisdictionUS')}
                </button>
              </div>

              <label for="bt-domain-input" class="sr-only">{t(lang, 'borderTracer.placeholder')}</label>
              <input
                type="text"
                id="bt-domain-input"
                placeholder={t(lang, 'borderTracer.placeholder')}
                class="w-full px-5 py-3.5 rounded-xl bg-white border-2 border-border text-text-primary placeholder-text-muted focus:border-gold focus:ring-2 focus:ring-gold/20 outline-none transition-all text-lg"
                autocomplete="off"
                spellcheck="false"
              />
              <button
                id="bt-scan-btn"
                class="w-full py-3.5 bg-gold hover:bg-gold-light text-text-primary font-bold rounded-xl shadow-lg shadow-gold/25 hover:shadow-xl hover:shadow-gold/40 hover:-translate-y-0.5 transition-all text-lg cursor-pointer"
              >
                {t(lang, 'borderTracer.scanButton')}
              </button>
            </div>
            <p class="text-xs text-text-secondary mt-3">
              {t(lang, 'borderTracer.disclaimer')}
            </p>
          </div>
        </div>

        <!-- STATE 2: Scanning -->
        <div id="bt-panel-scanning" class="hidden">
          <div class="flex flex-col items-center lg:items-start gap-6 py-8">
            <span id="bt-scanning-domain" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gold/10 border border-gold/30 text-gold rounded-full text-sm font-medium">
              {t(lang, 'borderTracer.scanning')}
            </span>
            <div class="space-y-3 w-full max-w-sm">
              <div id="bt-scan-step-list" class="space-y-2"></div>
            </div>
          </div>
        </div>

        <!-- STATE 3: Results scorecard -->
        <div id="bt-panel-results" class="hidden">
          <div class="bg-white rounded-2xl border border-border overflow-hidden">
            <div class="px-5 py-4 bg-gold/10 border-b border-gold/20 flex items-center justify-between">
              <div class="flex items-center gap-2">
                <h3 class="font-display text-lg font-bold text-gold">{t(lang, 'borderTracer.scorecardTitle')}</h3>
                <span id="bt-result-jurisdiction-badge" class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1 rounded-full"></span>
              </div>
              <span id="bt-result-domain-badge" class="text-sm text-text-secondary font-mono"></span>
            </div>

            <div class="p-5">
              <!-- Score + Headline -->
              <div class="flex items-center gap-5 mb-6">
                <div class="relative w-24 h-24 shrink-0">
                  <svg class="w-full h-full -rotate-90" viewBox="0 0 120 120">
                    <circle cx="60" cy="60" r="52" fill="none" stroke="#e7e5e4" stroke-width="8"></circle>
                    <circle id="bt-score-ring" cx="60" cy="60" r="52" fill="none" stroke="#0891B2" stroke-width="8"
                      stroke-dasharray="326.73" stroke-dashoffset="326.73" stroke-linecap="round"
                      class="transition-all duration-1000 ease-out"></circle>
                  </svg>
                  <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span id="bt-score-number" class="text-2xl font-bold text-text-primary">0</span>
                    <span id="bt-score-grade" class="text-[10px] font-bold text-text-secondary">&mdash;</span>
                  </div>
                </div>
                <div>
                  <p id="bt-score-headline" class="text-base font-bold text-text-primary mb-2 leading-snug"></p>
                  <div class="flex flex-wrap gap-2">
                    <span id="bt-badge-risk" class="px-2.5 py-1 rounded-full text-xs font-bold"></span>
                    <span id="bt-badge-lockin" class="px-2.5 py-1 rounded-full text-xs font-bold bg-surface text-text-secondary"></span>
                  </div>
                </div>
              </div>

              <!-- Jurisdiction bar -->
              <div class="mb-6">
                <div class="flex justify-between text-xs text-text-secondary mb-1.5">
                  <span>EU <span id="bt-bar-eu-pct" class="text-green-600 font-bold"></span></span>
                  <span>US <span id="bt-bar-us-pct" class="text-red-600 font-bold"></span></span>
                  <span>Other <span id="bt-bar-other-pct" class="text-amber-600 font-bold"></span></span>
                </div>
                <div class="h-2.5 rounded-full bg-surface overflow-hidden flex">
                  <div id="bt-bar-eu" class="h-full bg-green-500 transition-all duration-700"></div>
                  <div id="bt-bar-us" class="h-full bg-red-500 transition-all duration-700"></div>
                  <div id="bt-bar-other" class="h-full bg-amber-500 transition-all duration-700"></div>
                </div>
              </div>

              <!-- Breakdown sections -->
              <div class="space-y-3">
                <div id="bt-section-hosting" class="hidden p-3 bg-surface rounded-lg border border-border">
                  <div class="flex items-center gap-2 mb-1">
                    <div class="w-2 h-2 rounded-full" id="bt-hosting-dot"></div>
                    <h4 class="text-xs font-bold text-text-primary uppercase tracking-wide">{t(lang, 'borderTracer.webHosting')}</h4>
                  </div>
                  <div id="bt-hosting-details" class="text-sm text-text-secondary"></div>
                </div>

                <div id="bt-section-email" class="hidden p-3 bg-surface rounded-lg border border-border">
                  <div class="flex items-center gap-2 mb-1">
                    <div class="w-2 h-2 rounded-full" id="bt-email-dot"></div>
                    <h4 class="text-xs font-bold text-text-primary uppercase tracking-wide">{t(lang, 'borderTracer.emailServers')}</h4>
                  </div>
                  <div id="bt-email-details" class="text-sm text-text-secondary space-y-1"></div>
                </div>

                <div id="bt-section-cdn" class="hidden p-3 bg-surface rounded-lg border border-border">
                  <div class="flex items-center gap-2 mb-1">
                    <div class="w-2 h-2 rounded-full bg-amber-500"></div>
                    <h4 class="text-xs font-bold text-text-primary uppercase tracking-wide">{t(lang, 'borderTracer.cdnProxy')}</h4>
                  </div>
                  <div id="bt-cdn-details" class="text-sm text-text-secondary"></div>
                </div>

                <div id="bt-section-thirdparty" class="hidden p-3 bg-surface rounded-lg border border-border">
                  <div class="flex items-center gap-2 mb-1">
                    <svg class="w-3.5 h-3.5 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <h4 class="text-xs font-bold text-text-primary uppercase tracking-wide">{t(lang, 'borderTracer.thirdParty')}</h4>
                  </div>
                  <div id="bt-thirdparty-list" class="flex flex-wrap gap-1.5 mt-1"></div>
                </div>
              </div>

              <!-- CTA -->
              <div class="mt-6 pt-5 border-t border-border text-center">
                <p id="bt-cta-text" class="text-sm text-text-secondary mb-3">
                  {t(lang, 'borderTracer.ctaEU')}
                </p>
                <button data-cal-trigger
                   class="inline-block w-full px-6 py-3.5 bg-gold hover:bg-gold-light text-text-primary font-semibold rounded-xl shadow-lg shadow-gold/25 hover:shadow-xl hover:shadow-gold/30 transition-all text-sm cursor-pointer">
                  {t(lang, 'borderTracer.ctaButton')}
                </button>
              </div>

              <!-- Scan again -->
              <div class="text-center mt-4">
                <button id="bt-scan-again-btn" class="text-sm text-gold hover:underline cursor-pointer">
                  {t(lang, 'borderTracer.scanAgain')}
                </button>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .bt-scan-step { transition: opacity 0.3s, color 0.3s; }
  #bt-globe-svg {
    aspect-ratio: 1;
  }
</style>

<script>
  import '../scripts/border-tracer';
</script>
