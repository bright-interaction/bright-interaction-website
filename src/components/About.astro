---
import { t } from '../i18n';
interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;
---

<section id="about" class="py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Photo on mobile -->
    <div class="lg:hidden flex justify-center mb-8">
      <picture>
        <source srcset="/images/tom.webp" type="image/webp" />
        <img
          src="/images/tom.jpg"
          alt="Tom Isgren"
          width="192"
          height="192"
          loading="lazy"
          class="w-48 h-48 object-cover rounded-2xl"
        />
      </picture>
    </div>

    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 items-start">
      <!-- Content — takes full width -->
      <div class="flex-1">
        <p class="text-xs font-mono font-bold text-gold-dark mb-4 tracking-widest uppercase">{t(lang, 'about.light.badge')}</p>

        <h2 class="text-3xl sm:text-4xl font-heading font-bold text-text-primary tracking-tight mb-6">
          {t(lang, 'about.light.title')}
        </h2>

        <div class="space-y-4 text-text-secondary leading-relaxed max-w-3xl">
          <p>{t(lang, 'about.light.p1')}</p>
          <p>{t(lang, 'about.light.p2')}</p>
          <p>{t(lang, 'about.light.p3')}</p>
        </div>

        <div class="mt-8 flex gap-8 text-sm">
          <div>
            <div class="text-2xl font-bold text-text-primary">100/100</div>
            <div class="text-text-secondary">{t(lang, 'about.light.stat1Label')}</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-text-primary">599</div>
            <div class="text-text-secondary">{t(lang, 'about.light.stat2Label')}</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-text-primary">1</div>
            <div class="text-text-secondary">{t(lang, 'about.light.stat3Label')}</div>
          </div>
        </div>
      </div>

      <!-- Desktop photo — sidebar -->
      <div class="hidden lg:block shrink-0">
        <picture>
          <source srcset="/images/tom.webp" type="image/webp" />
          <img
            src="/images/tom.jpg"
            alt="Tom Isgren"
            width="288"
            height="384"
            loading="lazy"
            class="w-72 h-auto object-cover rounded-2xl"
          />
        </picture>
      </div>
    </div>
  </div>
</section>
