---

<Layout
  title="Infrastructure & Compliance Insights | Bright Interaction"
  description="Practical guides on digital infrastructure, security compliance, and workflow automation for businesses navigating GDPR, NIS2, and modern IT."
>
  <Header />
  <main id="main-content" class="pt-24 pb-16 bg-surface min-h-screen">
    <!-- Hero Section -->
    <section class="relative py-16 overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-mono text-gold-dark mb-4 tracking-wide uppercase">Knowledge Base</p>
          <h1 class="text-4xl sm:text-5xl font-bold text-text-primary mb-6 tracking-tight">
            Insights & <span class="text-gold">Guides</span>
          </h1>
          <p class="text-xl text-text-secondary mb-6">
            Practical knowledge for navigating digital infrastructure, compliance regulations, and automation.
            Complex topics explained in plain language.
          </p>
          <p class="text-text-secondary">
            We help Swedish businesses take control of their digital infrastructure. From GDPR and NIS2 compliance
            to self-hosted alternatives and workflow automation. Our guides are based on real implementation experience,
            including scanning <strong class="text-text-primary">597 Swedish law firms</strong> and auditing
            <strong class="text-text-primary">17 cybersecurity companies</strong>.
          </p>
        </div>
      </div>
    </section>

    <!-- Topic Clusters -->
    <section class="pb-8">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl border border-border p-6">
            <h2 class="text-lg font-bold text-text-primary mb-2">Compliance & GDPR</h2>
            <p class="text-text-secondary text-sm mb-3">GDPR, NIS2, CLOUD Act, cookie consent, and data sovereignty for European businesses.</p>
            <div class="flex flex-wrap gap-2">
              <a href="/insights/cloud-act-gdpr-conflict" class="text-gold-dark text-xs hover:text-gold transition-colors">CLOUD Act vs GDPR</a>
              <span class="text-border">|</span>
              <a href="/insights/gdpr-nis2-compliance-guide" class="text-gold-dark text-xs hover:text-gold transition-colors">GDPR & NIS2 Guide</a>
              <span class="text-border">|</span>
              <a href="/insights/nis2-compliance-checklist" class="text-gold-dark text-xs hover:text-gold transition-colors">NIS2 Checklist</a>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-border p-6">
            <h2 class="text-lg font-bold text-text-primary mb-2">SaaS Comparisons</h2>
            <p class="text-text-secondary text-sm mb-3">Real cost comparisons and migration guides for replacing SaaS with open source.</p>
            <div class="flex flex-wrap gap-2">
              <a href="/insights/google-workspace-alternative-gdpr" class="text-gold-dark text-xs hover:text-gold transition-colors">Google Workspace Alt.</a>
              <span class="text-border">|</span>
              <a href="/insights/coolify-vs-vercel" class="text-gold-dark text-xs hover:text-gold transition-colors">Coolify vs Vercel</a>
              <span class="text-border">|</span>
              <a href="/insights/slack-vs-mattermost-gdpr" class="text-gold-dark text-xs hover:text-gold transition-colors">Slack vs Mattermost</a>
              <span class="text-border">|</span>
              <a href="/insights/auth0-alternatives-europe" class="text-gold-dark text-xs hover:text-gold transition-colors">Auth0 Alternatives</a>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-border p-6">
            <h2 class="text-lg font-bold text-text-primary mb-2">Industry Reports</h2>
            <p class="text-text-secondary text-sm mb-3">Original research, audit data, and cost analysis from real implementations.</p>
            <div class="flex flex-wrap gap-2">
              <a href="/insights/cybersecurity-industry-benchmark" class="text-gold-dark text-xs hover:text-gold transition-colors">17 Cybersec Companies</a>
              <span class="text-border">|</span>
              <a href="/insights/saas-cost-per-employee" class="text-gold-dark text-xs hover:text-gold transition-colors">SaaS Cost Analysis</a>
              <span class="text-border">|</span>
              <a href="/insights/website-security-audit-cost" class="text-gold-dark text-xs hover:text-gold transition-colors">Audit Costs 2026</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Category Filter -->
    <section class="pb-4">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="filter-pills" class="flex flex-wrap gap-2">
          <button data-filter="all" class="filter-pill active px-4 py-2 rounded-full text-sm font-medium transition-colors">All</button>
          {[...new Set(insights.map(a => a.category))].map(cat => (
            <button data-filter={cat} class="filter-pill px-4 py-2 rounded-full text-sm font-medium transition-colors">{cat}</button>
          ))}
        </div>
      </div>
    </section>

    <!-- Articles Grid -->
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div id="insights-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {insights.map((article) => (
            <article data-category={article.category} class="group bg-white rounded-2xl border border-border hover:border-gold/30 transition-all overflow-hidden">
              <a href={`/insights/${article.slug}`} class="block p-6">
                <div class="flex items-center gap-3 mb-4">
                  <span class="px-3 py-1 bg-[#e0eff2] text-[#0a5e73] text-sm font-medium rounded-full">
                    {article.category}
                  </span>
                  {article.featured && (
                    <span class="px-3 py-1 bg-surface text-text-secondary text-sm rounded-full">
                      Featured
                    </span>
                  )}
                </div>
                <h2 class="text-xl font-bold text-text-primary mb-3 group-hover:text-gold transition-colors">
                  {article.title}
                </h2>
                <p class="text-text-secondary mb-4 line-clamp-3">
                  {article.excerpt}
                </p>
                <div class="flex items-center justify-between text-sm text-text-secondary">
                  <time datetime={article.date}>
                    {new Date(article.date).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                  <span>{article.readTime}</span>
                </div>
              </a>
            </article>
          ))}
        </div>

        {insights.length === 0 && (
          <div class="text-center py-16">
            <p class="text-text-secondary text-lg">More insights coming soon.</p>
          </div>
        )}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="bg-white rounded-2xl border border-border p-8 md:p-12">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">
            Need Help with Compliance?
          </h2>
          <p class="text-text-secondary mb-8 max-w-2xl mx-auto">
            I help businesses achieve GDPR and NIS2 compliance
            with practical, secure infrastructure solutions.
          </p>
          <button
            data-cal-trigger
            class="inline-flex items-center gap-2 px-8 py-4 bg-gold hover:bg-gold-light text-text-primary font-semibold rounded-xl transition-colors cursor-pointer"
          >
            Book a Free Call
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </button>
        </div>
      </div>
    </section>

    <!-- Back to Home -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/" class="inline-flex items-center gap-2 text-gold-dark hover:text-gold transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .filter-pill {
    background: #ffffff;
    color: #52525b;
    border: 1px solid #e7e5e4;
    cursor: pointer;
  }
  .filter-pill:hover {
    border-color: rgba(8, 145, 178, 0.3);
    color: #0891B2;
  }
  .filter-pill.active {
    background: #0E7490;
    color: #ffffff;
    border-color: #0E7490;
  }
</style>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('#filter-pills .filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('#insights-grid [data-category]');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = pill.dataset.filter;
      cards.forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>
