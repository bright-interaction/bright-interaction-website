---
import { t, localePath } from '../i18n';
interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const navItems = [
  { href: localePath(lang, '/#real-cost'), label: t(lang, 'nav.calculator') },
  { href: localePath(lang, '/#services'), label: t(lang, 'nav.services') },
  { href: localePath(lang, '/#process'), label: t(lang, 'nav.process') },
  { href: localePath(lang, '/#about'), label: t(lang, 'nav.about') },
  { href: localePath(lang, '/insights'), label: t(lang, 'nav.insights') },
  { href: localePath(lang, '/platform'), label: 'Platform' },
  { href: localePath(lang, '/#contact'), label: t(lang, 'nav.contact') },
];

const altLang = lang === 'en' ? 'sv' : 'en';
const altLabel = lang === 'en' ? 'SV' : 'EN';
const currentLabel = lang === 'en' ? 'EN' : 'SV';

const currentPath = Astro.url.pathname;
const altPath = lang === 'en'
  ? `/sv${currentPath === '/' ? '' : currentPath}`
  : currentPath.replace(/^\/sv/, '') || '/';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-xl border-b border-border">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">

      <!-- Logo -->
      <a href={localePath(lang, '/')} class="flex items-center gap-2 group shrink-0">
        <div class="w-7 h-7 rounded bg-text-primary flex items-center justify-center">
          <span class="text-white font-mono font-bold text-sm">B</span>
        </div>
        <span class="hidden sm:inline font-mono font-bold text-sm text-text-primary tracking-tight">
          bright<span class="text-gold-dark">interaction</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-1.5 text-sm text-text-secondary hover:text-text-primary font-medium transition-colors"
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Right -->
      <div class="flex items-center gap-3">
        <a
          href={altPath}
          class="px-2 py-1 text-xs font-mono font-bold text-text-secondary hover:text-text-primary transition-colors"
          aria-label={`Switch to ${altLang === 'sv' ? 'Swedish' : 'English'}`}
        >
          {altLabel}
        </a>

        <button
          data-cal-trigger
          class="hidden sm:inline-flex px-4 py-1.5 bg-text-primary hover:bg-text-secondary text-white text-sm font-medium rounded-lg transition-colors cursor-pointer"
        >
          {t(lang, 'nav.getStarted')}
        </button>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-1.5 text-text-secondary hover:text-text-primary focus:outline-none"
          aria-label={t(lang, 'nav.toggleMenu')}
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-3 border-t border-border mt-1">
      <div class="flex flex-col pt-2">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm text-text-secondary hover:text-text-primary font-medium transition-colors"
          >
            {item.label}
          </a>
        ))}
        <div class="px-3 pt-2">
          <button
            data-cal-trigger
            class="w-full px-4 py-2 bg-text-primary hover:bg-text-secondary text-white font-medium rounded-lg text-sm text-center transition-colors cursor-pointer"
          >
            {t(lang, 'nav.getStarted')}
          </button>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    if (menuIcon) {
      menuIcon.setAttribute('d', isOpen
        ? 'M4 6h16M4 12h16M4 18h16'
        : 'M6 18L18 6M6 6l12 12'
      );
    }
  });

  document.querySelectorAll('#mobile-menu a, #mobile-menu button').forEach(el => {
    el.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuIcon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    });
  });
</script>
